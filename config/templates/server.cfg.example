########################################
# Game
########################################

set gamename rdr3

########################################
# Network
########################################

# Only change the IP if you are using a server with multiple network interfaces.
endpoint_add_tcp "0.0.0.0:30120"
endpoint_add_udp "0.0.0.0:30120"

sv_maxclients 48

# Required for server-side state awareness.
set onesync on

########################################
# Server Information
########################################

sv_hostname "Trembita Games | RDR2 Vanilla"

sets sv_projectName "Trembita Games RDR2 Vanilla"
sets sv_projectDesc "Vanilla-first RDR2 server template by Trembita Games and the Oxbay community"

load_server_icon server-icon.png

# Set an optional server info and connecting banner image url.
# Size doesn't matter, any banner sized image will be fine.
#sets banner_detail "https://url.to/image.png"
#sets banner_connecting "https://url.to/image.png"

########################################
# Tags
########################################

sets tags "vanilla,rdr2,ukraine,oxbay,trembita"

########################################
# Locale
########################################

sets locale "uk-UA"

########################################
# Resources
########################################

exec resources.cfg
exec trembita-resources.cfg

########################################
# Security
########################################

# Allows players to use scripthook-based plugins when set to 1.
sv_scriptHookAllowed 0

########################################
# Permissions
########################################

# Local permissions configuration.
# Generated from config/templates/permissions.cfg.example.
exec permissions.cfg

########################################
# Local Configuration
########################################

# Local secrets and machine-specific settings.
# Generated from config/templates/secrets.cfg.example.
exec secrets.cfg

########################################
# Optional
########################################

# set rcon_password "CHANGE_ME"
# sv_enforceGameBuild 1491
# sv_master1 ""
