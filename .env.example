# MariaDB host binding.
# Default: 127.0.0.1
#
# Use 127.0.0.1 for local-only access.
# Use 0.0.0.0 only if you intentionally want to expose the database
# on all host network interfaces.
MARIADB_HOST=127.0.0.1

# MariaDB host port.
# Default: 3306
#
# If port 3306 is already used by another local MySQL/MariaDB instance,
# change this value to something like 3307.
MARIADB_PORT=3306

# Root password for the MariaDB server.
# Change this value for any real environment.
MARIADB_ROOT_PASSWORD=redm

# Default database created during first container initialization.
MARIADB_DATABASE=redm

# Default application/user account created during first container initialization.
MARIADB_USER=redm

# Password for MARIADB_USER.
# Change this value for any real environment.
MARIADB_PASSWORD=redm