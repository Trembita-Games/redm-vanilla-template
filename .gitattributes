# Default text handling
* text=auto

# Lua source files
*.lua text eol=lf

# Shell scripts
*.sh text eol=lf

# PowerShell scripts
*.ps1 text eol=crlf

# Config and documentation files
*.cfg text eol=lf
*.conf text eol=lf
*.example text eol=lf
*.ini text eol=lf
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf

# GitHub / CI
.github/** text eol=lf

# Resource manifests
fxmanifest.lua text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.7z binary
*.zip binary
*.rar binary
